# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Groq — two separate keys from console.groq.com
GROQ_API_KEY_PARSE=gsk_your_parse_key_here   # JD parsing
GROQ_API_KEY_SCORE=gsk_your_score_key_here   # candidate scoring
GROQ_MODEL=openai/gpt-oss-120b               # do not change unless Groq deprecates

# CrustData — blank = mock mode (1,500 Supabase profiles)
CRUSTDATA_API_KEY=

# CORS — set to your Vercel URL in production
ALLOWED_ORIGIN=http://localhost:3000

PORT=8080
